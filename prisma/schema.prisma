// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("PARCEIRA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notifications Notification[]
  @@schema("public")
}

model Process {
  id                  String   @id @default(uuid())
  idSolicitacao       String   @default("")
  idSugopGeruso       String?
  projeto             String   @default("")
  municipio           String?
  regional            String?
  superintendencia    String?
  fluxoPassagem       String?
  fluxoTravessia      String?
  fluxoTravessiaLt    String?
  fluxoAmbiental      String?
  parceiraProjeto     String?
  dataEnvioObra       DateTime?
  
  // Campos de Controle
  pendenciaAnuencia   Boolean  @default(false)
  pendenciaTravessia  Boolean  @default(false)
  pendenciaAmbiental  Boolean  @default(false)
  
  statusTriagem       String   @default("PENDENTE") // PENDENTE, EM_APROVACAO, FINALIZADO
  dataImportacao      DateTime @default(now())
  dataAprovacao       DateTime?
  aprovadoPor         String?

  // Legacy fields
  inscricao           String?
  concessionaria      String?
  partner             String?
  statusInscricao     String   @default("NÃO INICIADO")
  statusInscricaoAnuencia String @default("NÃO INICIADO")
  statusInscricaoTravessia String @default("NÃO INICIADO")
  statusInscricaoAmbiental String @default("NÃO INICIADO")
  statusProjeto       String   @default("NÃO INICIADO")
  status              String   @default("NOVO")
  statusUpdatedAt     DateTime @default(now())
  statusAnuencia      String?
  statusAmbiental     String?
  statusTravessia     String?
  data_triagem        DateTime?
  protocol            String?
  valor               String?
  dataVencimento      String?
  tipo                String?
  rodovia             String?
  km                  String?
  taxa                String?
  taxaPaga            Boolean  @default(false)
  sla                 String?
  sharepointFolderId  String?
  module              String   @default("travessia")
  observacaoInscricao String?  @default("")
  observacaoProjeto   String?  @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  movements           Movement[]
  protocols           Protocol[]
  @@schema("public")
}

model Protocol {
  id              String   @id @default(uuid())
  processId       String
  process         Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  numero          String
  numeroProcesso  String?
  tipo_fluxo      String   @default("TRAVESSIA")
  dataAprovacao   DateTime?
  observacao      String?
  status          String   @default("NOVO")
  concessionaria  String?
  dataProtocolo   DateTime?
  valor           String?
  dataVencimento  String?
  tipo            String?
  rodovia         String?
  km              String?
  taxa            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@schema("public")
}

model Movement {
  id          String   @id @default(uuid())
  processId   String
  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  description String
  date        DateTime @default(now())
  user        String
  module      String?  // The module where this movement happened
  tipo_fluxo  String   @default("TRAVESSIA")
  type        String?  // type of movement: 'status', 'origin', 'rejection', etc.
  @@schema("public")
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info")
  processId String?
  read      Boolean  @default(false)
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  @@schema("public")
}
