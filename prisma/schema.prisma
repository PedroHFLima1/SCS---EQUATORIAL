// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("PARCEIRA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notifications Notification[]
}

model Process {
  id                  String   @id @default(uuid())
  idSolicitacao       String   @default("")
  idSugopGeruso       String?
  projeto             String   @default("")
  municipio           String?
  regional            String?
  superintendencia    String?
  fluxoPassagem       String?
  fluxoTravessia      String?
  fluxoTravessiaLt    String?
  fluxoAmbiental      String?
  parceiraProjeto     String?
  dataEnvioObra       DateTime?
  
  // Campos de Controle
  pendenciaAnuencia   Boolean  @default(false)
  pendenciaTravessia  Boolean  @default(false)
  pendenciaAmbiental  Boolean  @default(false)
  
  statusTriagem       String   @default("PENDENTE") // PENDENTE, EM_APROVACAO, FINALIZADO
  dataImportacao      DateTime @default(now())

  // Legacy fields
  inscricao           String?
  concessionaria      String?
  partner             String?
  status              String   @default("NOVO")
  protocol            String?
  valor               String?
  dataVencimento      String?
  tipo                String?
  rodovia             String?
  km                  String?
  sla                 String?
  module              String   @default("travessia")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  movements           Movement[]

  @@unique([idSolicitacao, projeto])
}

model Movement {
  id          String   @id @default(uuid())
  processId   String
  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  description String
  date        DateTime @default(now())
  user        String
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info")
  processId String?
  read      Boolean  @default(false)
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}
